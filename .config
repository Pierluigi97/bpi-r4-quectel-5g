# Driver Kernel PCIe nativo per modem Quectel
CONFIG_PACKAGE_kmod-quectel_MHI=y

# Gestore ufficiale di connessione Quectel per Snapdragon X75
CONFIG_PACKAGE_quectel_cm_5G=y

# Nuova interfaccia grafica di Siriling e utility AT/SMS
CONFIG_PACKAGE_luci-app-modem=y
CONFIG_PACKAGE_sms-tool=y
CONFIG_PACKAGE_sendat=y

# DISATTIVIAMO il driver MediaTek standard per evitare conflitti PCIe
CONFIG_PACKAGE_kmod-mtk_t7xx=n
