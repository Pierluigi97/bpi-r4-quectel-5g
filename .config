# =================================================================
# 1. HARDWARE PRINCIPALE (BANANA PI BPI-R4)
# =================================================================
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_bananapi_bpi-r4=y

# =================================================================
# 2. PORTA M.2 - MODEM 5G PCIE QUECTEL (SIRILING)
# =================================================================
CONFIG_PACKAGE_kmod-quectel_MHI=y
CONFIG_PACKAGE_quectel_cm_5G=y
CONFIG_PACKAGE_luci-app-modem=y
CONFIG_PACKAGE_sms-tool=y
CONFIG_PACKAGE_sendat=y
# Disattivato per evitare che il driver generico t7xx (se presente nell'albero)
# intercetti il dispositivo PCIe al posto di quectel_MHI. Se il pacchetto non
# esiste nel tuo albero sorgenti questa riga viene semplicemente ignorata.
CONFIG_PACKAGE_kmod-mtk_t7xx=n

# =================================================================
# 3. SCHEDA AGGIUNTIVA WI-FI 7 (BPI-R4-NIC-BE14)
# =================================================================
# Driver mac80211 + firmware per il chip MediaTek MT7996.
# NB: il device profile "bananapi_bpi-r4" seleziona GIA' in automatico
# kmod-mt7996-firmware e kmod-mt7996-233-firmware (variante 2+3+3 antenne,
# quella usata dalla BE14): renderli espliciti qui non fa male, e' solo
# una garanzia in piu'.
CONFIG_PACKAGE_kmod-mt7996e=y
CONFIG_PACKAGE_kmod-mt7996-firmware=y
CONFIG_PACKAGE_kmod-mt7996-233-firmware=y
# Necessario per gestire Wi-Fi 7, MLO e WPA3-SAE
CONFIG_PACKAGE_wpad-openssl=y

# =================================================================
# 4. COMPATIBILITA' PORTE 2x SFP+
# =================================================================
CONFIG_PACKAGE_kmod-sfp=y
CONFIG_PACKAGE_kmod-phy-marvell=y
CONFIG_PACKAGE_kmod-phy-realtek=y
CONFIG_PACKAGE_kmod-phy-aquantia=y
CONFIG_PACKAGE_kmod-phy-broadcom=y

# =================================================================
# 5. SUPPORTO PORTE USB 3.2 E SLOT NVME M.2
# =================================================================
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-serial=y
CONFIG_PACKAGE_kmod-usb-serial-option=y
CONFIG_PACKAGE_kmod-usb-serial-wwan=y
CONFIG_PACKAGE_kmod-nvme=y

# =================================================================
# 6. INTERFACCIA WEB, STRUMENTI DI RETE E DIAGNOSTICA
# =================================================================
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl=y
CONFIG_PACKAGE_pciutils=y
CONFIG_PACKAGE_usbutils=y
CONFIG_PACKAGE_ethtool=y
# Tema grafico Argon
CONFIG_PACKAGE_luci-theme-argon=y
